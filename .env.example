# ========================================
# フロントエンド (frontend/.env にコピー)
# ========================================
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Railway にデプロイした FastAPI サーバーのURL
VITE_API_BASE_URL=https://your-app.up.railway.app

# ========================================
# バックエンド (backend/.env にコピー or Railwayの環境変数に設定)
# ========================================
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# Tripo3D APIキー (https://tripo3d.ai → API Keys)
TRIPO3D_API_KEY=your_tripo3d_api_key

# HuggingFace アクセストークン (Wonder3D用)
HUGGINGFACE_TOKEN=your_huggingface_token

# Firebase サービスアカウントJSON (1行JSON文字列)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
